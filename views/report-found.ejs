<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Campus Lost & Found - Report Item</title>
    <link rel="stylesheet" href="/css/form.css" />
  </head>
  <body>
    <div class="container">
      <div class="form-card">
        <h2>Found Item Submission Form</h2>
        <p class="subtitle">
          Please provide details about the item you found to help reunite it
          with its owner. Fields marked <span class="required">*</span> are
          required.
        </p>

        <form
          action="/submit-found-report"
          method="POST"
          enctype="multipart/form-data"
        >
          <div class="form-grid">
            <div class="left-col">
              <section>
                <h3>Founder Information</h3>
                <div class="row-3">
                  <div class="form-group">
                    <label>Name<span class="required">*</span></label>
                    <input type="text" name="founderName" required />
                  </div>
                  <div class="form-group">
                    <label>Email Address<span class="required">*</span></label>
                    <input type="email" name="email" required />
                  </div>
                  <div class="form-group">
                    <label>Phone Number<span class="required">*</span></label>
                    <input type="tel" name="phone" required />
                  </div>
                </div>
                <div class="form-group">
                  <label>Relation to Campus</label>
                  <select name="relation">
                    <option value="student">Student</option>
                    <option value="faculty">Faculty</option>
                    <option value="staff">Staff</option>
                    <option value="visitor">Visitor</option>
                  </select>
                </div>
              </section>

              <section>
                <h3>Item Description</h3>
                <div class="form-group">
                  <label>Item Type<span class="required">*</span></label>
                  <select name="itemType" required>
                    <option value="">
                      Keys, Wallet, Backpack, Electronics, etc.
                    </option>
                    <option value="electronics">Electronics</option>
                    <option value="clothing">Clothing</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Item Brand/Color<span class="required">*</span></label>
                  <input
                    type="text"
                    name="brandColor"
                    placeholder="e.g., Black Herschel Backpack"
                    required
                  />
                </div>
                <div class="form-group">
                  <label>Found Location<span class="required">*</span></label>
                  <input
                    type="text"
                    name="location"
                    placeholder="e.g., Library 3rd Floor"
                    required
                  />
                </div>
                <div class="form-group">
                  <label>Found Date<span class="required">*</span></label>
                  <input type="date" name="foundDate" required />
                </div>
                <div class="form-group">
                  <label>Additional Details</label>
                  <textarea
                    name="details"
                    rows="4"
                    placeholder="Small scratch on top, contains water bottle, etc."
                  ></textarea>
                </div>
              </section>
            </div>

            <div class="right-col">
              <section>
                <h3>Item Image</h3>
                <div class="image-upload-box">
                  <label
                    >Attach Photo of Found Item<span class="required"
                      >*</span
                    ></label
                  >
                  <div class="upload-zone">
                    <input
                      type="file"
                      name="itemImage"
                      id="imageInput"
                      required
                    />
                    <div class="preview-area">
                      <img
                        src="/placeholder-icon.png"
                        alt="Preview"
                        class="preview-icon"
                      />
                      <p>Preview</p>
                      <span class="file-name">image_item.jpg</span>
                    </div>
                  </div>
                </div>
              </section>
            </div>
          </div>

          <div class="form-footer">
            <button type="button" class="btn-secondary">Back to Listing</button>
            <button type="submit" class="btn-primary">
              Submit Found Report
            </button>
          </div>
        </form>
      </div>
    </div>
  </body>
</html>
