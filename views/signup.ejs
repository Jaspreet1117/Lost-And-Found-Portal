<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title><%= typeof title !== 'undefined' ? title : "Sign Up" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family:
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        /* Using the background image you selected */
        background-image: url("https://i.pinimg.com/1200x/41/74/b9/4174b96d7a37d5982fe53cba5343beab.jpg");
        background-repeat: no-repeat;
        background-size: cover;
        background-position: center;
      }

      .auth-wrapper {
        width: 100%;
        max-width: 400px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .auth-card {
        width: 100%;
        background: rgba(40, 40, 40, 0.55);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border-radius: 22px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        padding: 40px 36px;
        box-shadow: 0 12px 48px rgba(0, 0, 0, 0.45);
      }

      .auth-title {
        font-size: 28px;
        font-weight: 600;
        text-align: center;
        margin-bottom: 24px;
      }

      .field {
        margin-bottom: 20px;
      }

      .field label {
        display: block;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.85);
        margin-bottom: 6px;
      }

      .input-row {
        display: flex;
        align-items: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.55);
        padding-bottom: 6px;
        gap: 8px;
      }

      .input-row input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        font-size: 15px;
        color: #ffffff;
      }

      .primary-btn {
        width: 100%;
        margin-top: 24px;
        padding: 14px;
        border: none;
        border-radius: 999px;
        background: rgb(23, 23, 106);
        color: #ffffff;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.1s ease;
      }

      .primary-btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.2);
      }

      .footer-text {
        margin-top: 16px;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.75);
        text-align: center;
      }

      .footer-text a {
        color: #a5c7ff;
        font-weight: 700;
        text-decoration: none;
      }
    </style>
  </head>

  <body>
    <div class="auth-wrapper">
      <div class="auth-card">
        <h1 class="auth-title">Sign Up</h1>

        <form id="signupForm">
          <div class="field">
            <label for="fullname">Full Name</label>
            <div class="input-row">
              <input
                type="text"
                id="fullname"
                name="fullname"
                required
                placeholder="Enter your full name"
              />
            </div>
          </div>

          <div class="field">
            <label for="username">Email</label>
            <div class="input-row">
              <input
                type="email"
                id="username"
                name="username"
                required
                placeholder="Email address"
              />
            </div>
          </div>

          <div class="field">
            <label for="pwd1">Password</label>
            <div class="input-row">
              <input
                type="password"
                id="pwd1"
                name="password"
                required
                placeholder="Create password"
              />
            </div>
          </div>

          <button type="submit" class="primary-btn">Create Account</button>
        </form>

        <p
          id="signupMessage"
          class="footer-text"
          style="min-height: 18px; margin-top: 10px"
        ></p>

        <p class="footer-text">
          Already have an account?
          <a href="/login">Log In</a>
        </p>
      </div>
    </div>

    <script>
      document
        .getElementById("signupForm")
        .addEventListener("submit", function (e) {
          e.preventDefault();

          const messageEl = document.getElementById("signupMessage");
          const fullname = document.getElementById("fullname").value;
          const username = document.getElementById("username").value;
          const password = document.getElementById("pwd1").value;

          // POST request to send data to the server
          fetch("/signup", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ fullname, username, password }),
          })
            .then((res) => res.json())
            .then((data) => {
              if (data.success) {
                messageEl.textContent =
                  "Account created! Redirecting to login...";
                messageEl.style.color = "#4ade80";
                setTimeout(() => {
                  window.location.href = "/login";
                }, 1200);
              } else {
                messageEl.textContent = data.message || "Signup failed";
                messageEl.style.color = "#f87171";
              }
            })
            .catch((err) => {
              messageEl.textContent = "Server connection error";
              messageEl.style.color = "#f87171";
            });
        });
    </script>
  </body>
</html>
