<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Sign Up - Lost and Found Portal</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      .signup-page-wrapper {
        font-family: system-ui;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #dde5ed, #d0d6e6);
        position: relative;
        overflow: hidden;
      }

      .signup-page-wrapper::before,
      .signup-page-wrapper::after {
        content: "";
        position: fixed;
        border-radius: 50%;
        z-index: -1;
      }
      .signup-page-wrapper::before {
        top: -50%;
        right: -10%;
        width: 500px;
        height: 500px;
        background: rgba(255, 255, 255, 0.5);
        animation: float 13s infinite ease-in-out;
      }
      .signup-page-wrapper::after {
        bottom: -30%;
        left: -5%;
        width: 400px;
        height: 400px;
        background: rgba(255, 255, 255, 0.3);
        animation: float 25s infinite ease-in-out reverse;
      }

      @keyframes float {
        0%,
        100% {
          transform: translateY(0px);
        }
        50% {
          transform: translateY(50px);
        }
      }

      .signup-page-wrapper .auth-card {
        width: 340px;
        padding: 35px;
        border-radius: 20px;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(20px);
        color: white;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
      }

      .signup-page-wrapper h2 {
        text-align: center;
        margin-bottom: 20px;
      }

      .signup-page-wrapper .field {
        margin-bottom: 15px;
      }

      .signup-page-wrapper input:not([type="file"]) {
        width: 100%;
        border: none;
        border-bottom: 1px solid white;
        background: transparent;
        color: white;
        padding: 8px 0;
        outline: none;
        font-size: 14px;
      }

      .signup-page-wrapper input::placeholder {
        color: rgba(255, 255, 255, 0.5);
      }

      .signup-page-wrapper .primary-btn {
        width: 100%;
        padding: 12px;
        border-radius: 25px;
        border: none;
        background: #1e1b6b;
        color: white;
        margin-top: 15px;
        cursor: pointer;
        font-size: 15px;
        transition: background 0.2s;
      }

      .signup-page-wrapper .primary-btn:hover {
        background: #2a26a5;
      }
      .signup-page-wrapper .primary-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .signup-page-wrapper .profile-wrapper {
        text-align: center;
        margin-bottom: 20px;
      }

      .signup-page-wrapper .image-container {
        position: relative;
        width: 100px;
        height: 100px;
        margin: 0 auto;
        border-radius: 50%;
        border: 3px solid white;
        overflow: hidden;
        cursor: pointer;
        background: rgba(255, 255, 255, 0.1);
      }

      .signup-page-wrapper .image-container img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition:
          transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
          opacity 0.3s;
      }

      .signup-page-wrapper #preview {
        opacity: 0.7;
        transform: translateY(0);
      }

      .signup-page-wrapper .upload-icon {
        transform: translateY(100%);
        opacity: 0;
        padding: 22px;
      }

      .signup-page-wrapper .image-container:hover #preview {
        transform: translateY(-100%);
        opacity: 0;
      }

      .signup-page-wrapper .image-container:hover .upload-icon {
        transform: translateY(0);
        opacity: 1;
      }

      .signup-page-wrapper .footer-text {
        margin-top: 16px;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.75);
        text-align: center;
      }

      .signup-page-wrapper .footer-text a {
        color: #a5c7ff;
        font-weight: 700;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <div class="signup-page-wrapper">
      <div class="auth-card">
        <h2>Sign Up</h2>

        <form id="signupForm">
          <div class="profile-wrapper">
            <div class="image-container" id="imageContainer">
              <img id="preview" src="/images/camera_icon.webp" alt="profile" />
              <img
                class="upload-icon"
                src="/images/upload.png"
                alt="upload"
                style="background-size: cover; width: 100%; height: 100%"
              />
            </div>
            <input
              type="file"
              id="profilePic"
              accept="image/*"
              style="display: none"
            />
          </div>

          <div class="field">
            <input type="text" id="fullname" placeholder="Full Name" required />
          </div>

          <div class="field">
            <input type="email" id="username" placeholder="Email" required />
          </div>

          <div class="field">
            <input type="password" id="pwd1" placeholder="Password" required />
          </div>

          <div class="field">
            <input
              type="password"
              id="pwd2"
              placeholder="Confirm Password"
              required
            />
          </div>

          <button type="submit" class="primary-btn" id="signupBtn">
            Create Account
          </button>
        </form>

        <p id="msg" class="footer-text"></p>

        <p class="footer-text">
          Already have an account? <a href="/login">Log In</a>
        </p>
      </div>
    </div>

    <script>
      const fileInput = document.getElementById("profilePic");
      const imageContainer = document.getElementById("imageContainer");
      const preview = document.getElementById("preview");

      imageContainer.addEventListener("click", () => fileInput.click());

      fileInput.addEventListener("change", () => {
        const file = fileInput.files[0];
        if (file) {
          preview.src = URL.createObjectURL(file);
          preview.style.opacity = "1";
        }
      });

      document
        .getElementById("signupForm")
        .addEventListener("submit", async function (e) {
          e.preventDefault();

          const btn = document.getElementById("signupBtn");
          const msg = document.getElementById("msg");
          const pwd1 = document.getElementById("pwd1").value;
          const pwd2 = document.getElementById("pwd2").value;

          if (pwd1 !== pwd2) {
            msg.textContent = "Passwords do not match";
            msg.style.color = "#f87171";
            return;
          }

          btn.disabled = true;
          btn.textContent = "Creating…";
          msg.textContent = "";

          const formData = new FormData();
          formData.append(
            "fullname",
            document.getElementById("fullname").value,
          );
          formData.append(
            "username",
            document.getElementById("username").value,
          );
          formData.append("password", pwd1);
          if (fileInput.files[0])
            formData.append("profilePic", fileInput.files[0]);

          try {
            const res = await fetch("/signup", {
              method: "POST",
              body: formData,
            });
            const data = await res.json();

            if (data.success) {
              msg.textContent = "Account created! Redirecting…";
              msg.style.color = "lightgreen";
              setTimeout(() => (window.location.href = "/login"), 1200);
            } else {
              msg.textContent = data.message || "Signup failed";
              msg.style.color = "#f87171";
              btn.disabled = false;
              btn.textContent = "Create Account";
            }
          } catch {
            msg.textContent = "Server error. Please try again.";
            msg.style.color = "#f87171";
            btn.disabled = false;
            btn.textContent = "Create Account";
          }
        });
    </script>
  </body>
</html>
