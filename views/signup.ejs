<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Sign Up - Lost and Found Portal</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        /* Using your provided Blue Image as background */
        background: url("/images/signup_bg1.png") no-repeat center center fixed;
        background-size: cover;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .signup-page-wrapper {
        width: 100%;
        max-width: 1000px;
        height: 580px;
        display: flex;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(15px);
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 25px 45px rgba(2, 53, 57, 0.5);
        margin: 20px;
      }

      /* Left Side - Welcome Section */
      /* .welcome-section {
        flex: 1;
        padding: 60px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        color: white;
        /* background: linear-gradient(to right, rgba(171, 174, 174, 0.5), transparent); */
      /* background-color: #999, transparent; */
      /* opacity: 0.4; */
      /* } */

      .welcome-section {
        flex: 1;
        padding: 60px 45px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        color: var(--text-primary);
        z-index: 2;
        background-color: var(--glass-color);
        border-right: 1px solid rgba(255, 255, 255, 0.03);
      }

      .welcome-section h1 {
        font-size: 38px;
        margin-bottom: 20px;
        font-weight: 700;
        color: white;
      }

      .welcome-section p {
        font-size: 16px;
        line-height: 1.8;
        /* color: var(--text-secondary); */
        color: rgba(255, 255, 255, 0.745);
      }

      /* Isse pura container thoda utha hua lagega bina dark dikhe */
      .signup-page-wrapper {
        background: rgba(21, 3, 3, 0.353); /* Almost zero visibility */
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
        /* border: 1px solid rgba(255, 255, 255, 0.1); */
      }

      /* .welcome-section h1 {
        font-size: 2.5rem;
        margin-bottom: 20px;
        font-weight: 700;
        color: black;
      }

      .welcome-section p {
        font-size: 1rem;
        line-height: 1.6;
        /* color: #cccccc; */
      /* color: black; */
      /* } */

      /* Right Side - Form Section */
      .auth-card {
        flex: 1;
        padding: 40px 60px;
        padding-top: 50px;
        /* padding-bottom: 0px; */
        /* background: rgba(255, 255, 255, 0.627); */
        background: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        border-left: 1px solid rgba(255, 255, 255, 0.1);
      }

      .auth-card h2 {
        color: black;
        font-size: 1.8rem;
        margin-bottom: 30px;
        text-align: left;
      }

      .field {
        margin-bottom: 16px;
        position: relative;
      }

      .field input:not([type="file"]) {
        width: 100%;
        padding: 10px 0;
        background: transparent;
        border: none;
        border-bottom: 1px solid #444;
        color: black;
        outline: none;
        font-size: 14px;
        transition: border-color 0.3s;
      }

      .field input:focus {
        border-bottom-color: #14bbcd; /* Green focus like the UI ref */
      }

      /* Profile Picture Styles */
      .profile-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 0px;
        margin-bottom: 5px;
        width: auto;
        max-width: fit-content;
        margin-left: auto;
        margin-right: auto;
      }

      .image-container {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        border: 2px solid #575656;
        overflow: hidden;
        cursor: pointer;
        position: relative;
        background: rgba(255, 255, 255, 0.05);
        /* //// */
        display: flex;
        justify-content: center;
        align-items: center;
      }

      .image-container img {
        width: 100%;
        height: 100%;
        /* width: 28px; */
        /* height: 28px; */
        /* filter: invert(100%) brightness(100%); */
        transition: opacity 0.3s;
        object-fit: cover;
        opacity: 0.8;
      }

      .primary-btn {
        width: 100%;
        padding: 12px;
        background: #0f86c1; /* Forest green color */
        color: white;
        border: none;
        border-radius: 4px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 5px;
        margin-bottom: 0px;
        transition: background 0.3s;
      }

      .primary-btn:hover {
        background: #10aeb9;
      }

      .primary-btn:disabled {
        background: #064e52;
        cursor: not-allowed;
      }

      .footer-text {
        margin-top: 16px;
        font-size: 13px;
        color: #999;
        text-align: center;
      }

      .footer-text a {
        color: #10abb9;
        text-decoration: none;
        font-weight: 600;
      }

      /* Responsive */
      @media (max-width: 768px) {
        .welcome-section {
          display: none;
        }
        .signup-page-wrapper {
          max-width: 400px;
        }
      }
    </style>
  </head>
  <body>
    <div class="signup-page-wrapper">
      <div class="welcome-section">
        <h1>Let's Get Started</h1>
        <p>
          Join our community to help reunite lost items with their rightful
          owners. Simple, secure, and helpful.
        </p>
      </div>

      <div class="auth-card">
        <h2>Sign up</h2>

        <form id="signupForm">
          <div class="profile-wrapper">
            <div
              class="image-container"
              id="imageContainer"
              title="Upload Profile Picture"
            >
              <img id="preview" src="/images/camera_icon.webp" alt="profile" />
            </div>
            <input
              type="file"
              id="profilePic"
              accept="image/*"
              style="display: none"
            />
          </div>

          <div class="field">
            <input type="text" id="fullname" placeholder="Full Name" required />
          </div>

          <div class="field">
            <input type="email" id="username" placeholder="Email" required />
          </div>

          <div class="field">
            <input type="text" id="userId" placeholder="User ID" required />
          </div>

          <div class="field">
            <input
              type="password"
              id="pwd1"
              placeholder="Create Password"
              required
            />
          </div>

          <div class="field">
            <input
              type="password"
              id="pwd2"
              placeholder="Repeat Password"
              required
            />
          </div>

          <button type="submit" class="primary-btn" id="signupBtn">
            Sign up
          </button>
        </form>

        <p id="msg" class="footer-text"></p>

        <p class="footer-text">
          Already a Member? <a href="/login">Sign in here</a>
        </p>
      </div>
    </div>

    <script>
      /* Logic remains untouched as requested */
      const fileInput = document.getElementById("profilePic");
      const imageContainer = document.getElementById("imageContainer");
      const preview = document.getElementById("preview");

      imageContainer.addEventListener("click", () => fileInput.click());

      fileInput.addEventListener("change", () => {
        const file = fileInput.files[0];
        if (file) {
          preview.src = URL.createObjectURL(file);
          preview.style.opacity = "1";
        }
      });

      document
        .getElementById("signupForm")
        .addEventListener("submit", async function (e) {
          e.preventDefault();

          const btn = document.getElementById("signupBtn");
          const msg = document.getElementById("msg");
          const pwd1 = document.getElementById("pwd1").value;
          const pwd2 = document.getElementById("pwd2").value;

          if (pwd1 !== pwd2) {
            msg.textContent = "Passwords do not match";
            msg.style.color = "#f87171";
            return;
          }

          btn.disabled = true;
          btn.textContent = "Creating…";
          msg.textContent = "";

          const formData = new FormData();
          formData.append(
            "fullname",
            document.getElementById("fullname").value,
          );
          formData.append(
            "username",
            document.getElementById("username").value,
          );
          formData.append("userId", document.getElementById("userId").value);
          formData.append("password", pwd1);
          if (fileInput.files[0])
            formData.append("profilePic", fileInput.files[0]);

          try {
            const res = await fetch("/signup", {
              method: "POST",
              body: formData,
            });
            const data = await res.json();

            if (data.success) {
              msg.textContent = "Account created! Redirecting…";
              msg.style.color = "lightgreen";
              setTimeout(() => (window.location.href = "/login"), 1200);
            } else {
              msg.textContent = data.message || "Signup failed";
              msg.style.color = "#f87171";
              btn.disabled = false;
              btn.textContent = "Sign up";
            }
          } catch {
            msg.textContent = "Server error. Please try again.";
            msg.style.color = "#f87171";
            btn.disabled = false;
            btn.textContent = "Sign up";
          }
        });
    </script>
  </body>
</html>
