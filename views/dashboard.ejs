<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/dashboard.css" />
    <link rel="stylesheet" href="/css/modal.css" />
    <title>Dashboard | Lost & Found</title>
    <script src="https://kit.fontawesome.com/0ed85649cd.js" crossorigin="anonymous"></script>
</head>
<body>
    <nav class="navbar">
        <div class="nav-content">
            <div class="logo-area">
                <i class="fa-solid fa-magnifying-glass-chart"></i>
                
            </div>
            <div class="nav-links">
                <a class="nav-link" href="/dashboard">HOME</a>
                <a class="nav-link active-link" href="/report-lost">REPORT LOST</a>
                <a class="nav-link"  href="/report-found">REPORT FOUND</a>
                <a class="nav-link"  href="/profile">PROFILE</a>
            </div>
        </div>
    </nav>

    <main class="main-layout">
        <div class="side-body">
            <header class="hero" style="text-align: center; display: flex; flex-direction: column; align-items: center;">
                <h1>REUNITING LOST THINGS.</h1>
                <p>Post or Search for missing items quickly!</p>
                <div class="action-buttons">
                    <button onclick="window.location.href='/report-lost'" class="btn-teal">REPORT LOST ITEM</button>
                    <button onclick="window.location.href='/report-found'" class="btn-gold">REPORT FOUND ITEM</button>
                </div>
                <div class="search-bar-container">
                    <input type="text" placeholder="SEARCH ITEMS..." />
                    <button class="search-icon-btn"><i class="fa-solid fa-magnifying-glass"></i></button>
                </div>
            </header>

            <div class="content-header">
                <h3 class="latest-listing">LOST LISTINGS</h3>
                <div class="segmented-control">
                    <input type="radio" name="status" id="lost-filter" checked />
                    <label for="lost-filter">Lost</label>
                    <input type="radio" name="status" id="found-filter" />
                    <label for="found-filter">Found</label>
                    <div class="selection-slider"></div>
                </div>
            </div>

            <div class="listings-grid">
                <% listings.forEach(item => { %>
                    <div class="post" data-description="<%= item.description %>">
                        <div class="user-post">
                            <div class="post-header-left">
                                <img class="post-logo" src="https://ui-avatars.com/api/?name=<%= item.username %>&background=random" alt="User" />
                                <div class="username">
                                    <h4><%= item.username %></h4>
                                    <p><%= item.timeAgo %></p>
                                </div>
                            </div>
                            <div class="found-item-action">
                               <button style="cursor: pointer;"
                                    class="<%= item.status === 'lost' ? 'item-found-btn' : '' %>" 
                                    onclick="window.location.href='<%= item.status === 'lost' ? '/report-found' : '/claim-item' %>'">
                                    <%= item.status === 'lost' ? 'Item Found' : 'Claim Item' %>
                                </button>
                            </div>
                        </div>

                        <div class="item">
                            <div class="item-image">
                                <img src="<%= item.image %>" alt="<%= item.title %>" />
                                <span class="status-badge <%= item.status %> <%= item.status === 'lost' ? 'pulse' : '' %>">
                                    <%= item.status.toUpperCase() %>
                                </span>
                            </div>
                            <div class="item-information">
                                <div class="info-top">
                                    <h2><%= item.title %></h2>
                                    <span class="category-tag"><%= item.category %></span>
                                </div>
                                <div class="info-middle">
                                    <p class="info-row">
                                        <span class="label">📍 Location</span>
                                        <span class="value"><%= item.location %></span>
                                    </p>
                                    <p class="info-row">
                                        <span class="label">📆 Date</span>
                                        <span class="value"><%= item.date %></span>
                                    </p>
                                </div>
                                <button class="view-details-btn">
                                    View Details <i class="fa-solid fa-arrow-right-long"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </main>

    <%- include('partials/modal') %>

    <script src="/js/modal.js"></script>
    <script src="/js/dashboard.js"></script>
</body>
</html>