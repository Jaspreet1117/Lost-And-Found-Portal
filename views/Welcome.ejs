<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/Welcome.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <title><%= title %></title>
</head>
<body>
    <section class="heroSection">
        <div class="floatingIcons">
            <div class ="float f1">🔑</div>
            <div class ="float f2">📱</div>
            <div class ="float f3">💼</div>
            <div class ="float f4">📦</div>
            <div class ="float f5">⌚</div>
            <div class ="float f6">🪪</div>
        </div>
        <div class="heroContent">
            <div class="badge">
                <span class="pulse-dot"></span>
                <span>12,690+ people already reunited with their belongings</span>
            </div>
            <div class="headline-animation">
                <h1 class="headline">
                    <span class ="tag t1">Lost Something?</span>
                    <span class ="tag t2">Found Something?</span>
                    <span class="tag t3">Reunite Here.</span>
                </h1>
            </div>
            <p class="subtext">
                Connect with your community to report, find, and recover lsot items effortlessly.
                One platform, thousands of reunions.
            </p>
            <div class="buttons">
                <button class ="button1">
                    <a href ='/login' style=" text-decoration: none; color :grey">Get Started — It's Free</a>
                </button>
                <button class ="button2">
                    <a href ='/login' style=" text-decoration: none; color: grey;">Sign In</a>
                </button>
            </div>
            <div class="scroll-indicator">
                <span>Scroll</span>
                <div class="scroll-bar"></div>
            </div>
        </div>
    </section>
    <section class="how-it-works-section">
      <div class="container">
        <div class="header-text">
          <span class="pretitle">SIMPLE PROCESS</span>
          <h2>How It Works</h2>
          <p>Three simple steps to reunite with what matters most.</p>
        </div>
        <div class="steps-grid">
          <!-- Step 1 -->
          <div class="step-card">
        <span class="step-number">01</span>
        <div class="icon-wrapper" style="--icon-bg: #fff1f2; --icon-color: #f43f5e;">
          <!-- Camera icon (simple line SVG) -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path>
            <circle cx="12" cy="13" r="4"></circle>
            
          </svg>
        </div>
        <h3>Report Your Item</h3>
        <p>Upload photos and details about your lost or found item in seconds.</p>
          </div>

          <!-- Step 2 -->
          <div class="step-card">
        <span class="step-number">02</span>
        <div class="icon-wrapper" style="--icon-bg: #fffbeb; --icon-color: #f59e0b;">
          <!-- Search icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </div>
        <h3>Community Search & Match</h3>
        <p>Browse the feed or let the community help you find your belongings.</p>
          </div>

          <!-- Step 3 -->
          <div class="step-card">
        <span class="step-number">03</span>
        <div class="icon-wrapper" style="--icon-bg: #ecfdf5; --icon-color: #10b981;">
          <!-- MessageCircle icon -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
        </div>
        <h3>Reconnect & Recover</h3>
        <p>Get in touch with the finder and arrange a safe handover.</p>
          </div>
        </div>
      </div>
    </section>
    <section class="trust-counters-section">
      <div class="container">
        <div class="stats-grid">
          <!-- Item 1 -->
          <div class="stat-card">
            <div class="icon-box" style="--bg: #fff1f2;">
              <!-- Heart SVG -->
              <svg viewBox="0 0 24 24" fill="none" stroke="#f43f5e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="number" data-target="4523">+</div>
            <div class="label">Items Reunited</div>
          </div>

          <!-- Item 2 -->
          <div class="stat-card">
            <div class="icon-box" style="--bg: #eff6ff;">
              <!-- Users SVG -->
              <svg viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <div class="number" data-target="12340">+</div>
            <div class="label">Active Users</div>
          </div>

          <!-- Item 3 -->
          <div class="stat-card">
            <div class="icon-box" style="--bg: #fffbeb;">
              <!-- MapPin SVG -->
              <svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="number" data-target="110">+</div>
            <div class="label">Cities Served</div>
          </div>
        </div>
      </div>
    </section>
    <section class="secondary-cta">
      <div class="background-blob top-right"></div>
      <div class="background-blob bottom-left"></div>

      <div class="content-container">
        <h2>Start by creating your first report</h2>
    
        <p class="subtitle">
          Whether you've lost something precious or found someone's belonging — every report brings us closer to a reunion.
        </p>

        <div class="button-group">
          <button class="btn btn-lost" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            Report Lost Item
          </button>

          <button class="btn btn-found" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            Report Found Item
          </button>
        </div>
      </div>
    </section>
    <section class="footer">
      <div class="footer">
        <div class ="icons">
          <div class="icon1"><i class="fa-brands fa-instagram"></i></div>
          <div class="icon2"><i class="fa-brands fa-facebook"></i></div>
          <div class="icon3"><i class="fa-brands fa-twitter"></i></div>
          <div class="icon4"><i class="fa-brands fa-linkedin"></i></div>
          <div class="icon5"><i class="fa-brands fa-github"></i></div>
        </div> 
        <div class="mainLine">
          <p class="mainLine1">

          </p>
        </div> 
      </div>
    </section>
    <script>
      document.addEventListener("DOMContentLoaded", () => { 
      const numbers = document.querySelectorAll(".number");

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");

              const target = parseInt(entry.target.getAttribute("data-target"), 10);
              let count = 0;
              const increment = Math.ceil(target / 60); 
              const interval = setInterval(() => {
                count += increment;
                if (count >= target) {
                  count = target;
                  clearInterval(interval);
                }
                entry.target.textContent = count.toLocaleString() + (target >= 1000 ? "+" : "");
              }, 25);

              observer.unobserve(entry.target); 
            }
          });
        },
        { threshold: 0.3, rootMargin: "0px 0px -80px 0px" }
      );

        numbers.forEach((num) => observer.observe(num));
      });
    </script>
</body>
</html>