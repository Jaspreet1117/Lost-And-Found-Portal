<div id="itemModal" class="modal-overlay">
  <div class="modal-container">
    <button class="modal-close" id="closeModal">&times;</button>

    <div class="modal-grid">
      <div class="modal-visuals">
        <div class="main-img-wrapper">
          <img id="modalImg" src="" alt="Item" />
          <span id="modalBadge" class="status-pill"></span>
        </div>
      </div>

      <div class="modal-details">
        <div class="header-group">
          <h1 id="modalTitle"></h1>
          <span id="modalCategory" class="category-tag"></span>
        </div>

        <div class="meta-info">
          <div class="meta-item">
            <i class="fa-solid fa-location-crosshairs"></i>
            <span
              ><strong>Location:</strong> <span id="modalLocation"></span
            ></span>
          </div>
          <div class="meta-item">
            <i class="fa-solid fa-calendar-check"></i>
            <span><strong>Date:</strong> <span id="modalDate"></span></span>
          </div>
        </div>

        <div class="description-box">
          <h3>Item Description</h3>
          <p id="modalDesc"></p>
        </div>

        <div class="modal-footer">
          <button class="btn-primary" id="contactPosterBtn">
            <i class="fa-solid fa-paper-plane"></i> Contact Poster
          </button>
          <button class="btn-secondary item-found-btn-modal" style="display:none; background:#2ecc71; color:white; border:none; border-radius:8px; padding:10px 20px; font-weight:bold; cursor:pointer;">
            <i class="fa-solid fa-circle-check"></i> Item Found
          </button>
          <button class="btn-secondary">
            <i class="fa-solid fa-heart"></i> Save
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ─── Claim Modal ─── -->
<div id="claimModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:3000; justify-content:center; align-items:center;">
  <div id="claimModalBox" style="background:#fff; border-radius:16px; padding:32px 28px; width:420px; max-width:95vw; box-shadow:0 20px 60px rgba(0,0,0,0.25); position:relative; animation: claimSlideIn 0.3s ease;">
    <button onclick="closeClaimModal()" style="position:absolute;top:14px;right:18px;background:none;border:none;font-size:22px;cursor:pointer;color:#999;">&times;</button>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
      <span style="font-size:26px;">🔍</span>
      <h2 style="margin:0;color:#008080;font-size:1.3rem;">I Found This Item!</h2>
    </div>
    <p style="color:#666;font-size:13px;margin-bottom:20px;">Fill in the details below. The owner will be notified immediately.</p>

    <div style="background:#f0fafa;border-radius:10px;padding:12px 14px;margin-bottom:18px;border-left:4px solid #008080;">
      <span style="font-size:12px;color:#888;text-transform:uppercase;letter-spacing:0.5px;">Item</span>
      <p id="claimItemTitle" style="margin:0;font-weight:700;color:#333;font-size:1rem;"></p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
      <div>
        <label style="display:block;font-size:13px;font-weight:600;color:#444;margin-bottom:6px;">👤 Your Name <span style="color:red;">*</span></label>
        <input id="claimFinderName" type="text" placeholder="e.g. Rahul Sharma" style="width:100%;padding:10px 12px;border:1.5px solid #ddd;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box;transition:border 0.2s;" onfocus="this.style.borderColor='#008080'" onblur="this.style.borderColor='#ddd'"/>
      </div>
      <div>
        <label style="display:block;font-size:13px;font-weight:600;color:#444;margin-bottom:6px;">📞 Contact Number <span style="color:red;">*</span></label>
        <input id="claimPhone" type="tel" placeholder="e.g. 9876543210" style="width:100%;padding:10px 12px;border:1.5px solid #ddd;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box;transition:border 0.2s;" onfocus="this.style.borderColor='#008080'" onblur="this.style.borderColor='#ddd'"/>
      </div>
    </div>

    <label style="display:block;font-size:13px;font-weight:600;color:#444;margin-bottom:6px;">📍 Where did you find it? <span style="color:red;">*</span></label>
    <input id="claimFoundWhere" type="text" placeholder="e.g. Near Gate 3, Library, Sector 15..." style="width:100%;padding:10px 12px;border:1.5px solid #ddd;border-radius:8px;font-size:14px;outline:none;margin-bottom:16px;box-sizing:border-box;transition:border 0.2s;" onfocus="this.style.borderColor='#008080'" onblur="this.style.borderColor='#ddd'"/>

    <label style="display:block;font-size:13px;font-weight:600;color:#444;margin-bottom:6px;">💬 Note to owner <span style="color:#aaa;font-weight:400;">(optional)</span></label>
    <textarea id="claimNote" rows="3" placeholder="Any extra info to help identify the item or arrange pickup..." style="width:100%;padding:10px 12px;border:1.5px solid #ddd;border-radius:8px;font-size:14px;outline:none;resize:none;margin-bottom:20px;box-sizing:border-box;transition:border 0.2s;" onfocus="this.style.borderColor='#008080'" onblur="this.style.borderColor='#ddd'"></textarea>

    <button onclick="submitClaim()" id="submitClaimBtn" style="width:100%;padding:12px;background:linear-gradient(135deg,#008080,#00b3b3);color:white;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;transition:transform 0.15s,box-shadow 0.15s;box-shadow:0 4px 15px rgba(0,128,128,0.35);" onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'">
      <i class="fa-solid fa-bell"></i> &nbsp;Notify Owner
    </button>
  </div>
</div>

<style>
@keyframes claimSlideIn {
  from { opacity: 0; transform: translateY(-20px) scale(0.96); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
</style>
