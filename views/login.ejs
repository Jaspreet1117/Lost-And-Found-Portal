<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Login - Lost and Found Portal</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      .login-page-wrapper {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: "Segoe UI", sans-serif;
        background: linear-gradient(135deg, #dde5ed 0%, #d0d6e6 100%);
        position: relative;
        overflow: hidden;
      }

      .login-page-wrapper .auth-card {
        width: 350px;
        padding: 35px;
        border-radius: 20px;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(20px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        color: white;
      }

      .login-page-wrapper .input-group {
        margin-bottom: 18px;
      }

      .login-page-wrapper .input-group label {
        font-size: 13px;
        opacity: 0.8;
        display: block;
        margin-bottom: 4px;
      }

      .login-page-wrapper .input-group input {
        width: 100%;
        border: none;
        border-bottom: 1px solid white;
        background: transparent;
        color: white;
        padding: 8px 0;
        outline: none;
        font-size: 14px;
      }

      .login-page-wrapper .input-group input::placeholder {
        color: rgba(255, 255, 255, 0.5);
      }

      .login-page-wrapper .btn {
        width: 100%;
        padding: 12px;
        border-radius: 25px;
        border: none;
        background: #1e1b6b;
        color: white;
        margin-top: 15px;
        cursor: pointer;
        font-size: 15px;
        transition: background 0.2s;
      }

      .login-page-wrapper .btn:hover {
        background: #2a26a5;
      }

      .login-page-wrapper .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .login-page-wrapper .google-btn {
        width: 100%;
        padding: 12px;
        border-radius: 25px;
        border: none;
        background: white;
        color: black;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        font-size: 14px;
        transition: background 0.2s;
      }

      .login-page-wrapper .google-btn:hover {
        background: #f1f1f1;
      }

      .login-page-wrapper .divider {
        text-align: center;
        margin: 15px 0;
        font-size: 12px;
        opacity: 0.7;
      }

      .login-page-wrapper .footer-text {
        text-align: center;
        margin-top: 15px;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.8);
      }

      .login-page-wrapper .footer-text a {
        color: #9ecbff;
        text-decoration: none;
        font-weight: 600;
      }

      #errorMsg {
        color: #f87171;
        font-size: 13px;
        text-align: center;
        margin-top: 10px;
        min-height: 18px;
      }
    </style>
  </head>
  <body>
    <div class="login-page-wrapper">
      <div class="auth-card">
        <h2 style="text-align: center; margin-bottom: 25px">Log In</h2>

        <form id="loginForm">
          <div class="input-group">
            <label>Email</label>
            <input
              type="email"
              id="username"
              placeholder="Enter your email"
              required
            />
          </div>

          <div class="input-group">
            <label>Password</label>
            <input
              type="password"
              id="pwd1"
              placeholder="Enter password"
              required
            />
          </div>

          <button type="submit" class="btn" id="loginBtn">Login</button>
        </form>

        <p id="errorMsg"></p>

        <div class="divider">OR</div>

        <!-- Google OAuth: simple link, no JS needed -->
        <a href="/auth/google" class="google-btn">
          <i class="fa-brands fa-google" style="color: #e50b0b"></i>
          Continue with Google
        </a>

        <p class="footer-text">
          Don't have an account? <a href="/signup">Sign Up</a>
        </p>
      </div>
    </div>

    <script>
      document
        .getElementById("loginForm")
        .addEventListener("submit", async function (e) {
          e.preventDefault();

          const btn = document.getElementById("loginBtn");
          const errorMsg = document.getElementById("errorMsg");
          btn.disabled = true;
          btn.textContent = "Logging in…";
          errorMsg.textContent = "";

          try {
            const res = await fetch("/login", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                username: document.getElementById("username").value,
                password: document.getElementById("pwd1").value,
              }),
            });

            const data = await res.json();

            if (data.success) {
              // Token is stored in httpOnly cookie by the server — just redirect
              window.location.href = "/dashboard";
            } else {
              errorMsg.textContent =
                data.message || "Invalid email or password";
              btn.disabled = false;
              btn.textContent = "Login";
            }
          } catch (err) {
            errorMsg.textContent = "Server error. Please try again.";
            btn.disabled = false;
            btn.textContent = "Login";
          }
        });
    </script>
  </body>
</html>
