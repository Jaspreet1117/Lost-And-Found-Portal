      /* .input-group input {
        width: 100%;
        padding: 12px 15px;
        /* background-color: rgba(0, 0, 0, 0.15); */
        /* border: 1px solid var(--input-border); */
        /* border-radius: 8px; */
        /* color: var(--text-primary); */
        /* outline: none; */
        /* font-size: 14px; */
        /* transition: all 0.3s ease; */
      /* }  */

      /* .input-group input:focus {
        border-color: var(--btn-color);
        box-shadow: 0 0 0 3px rgba(13, 135, 109, 0.1);
      } */

      .auth-card {
        width: 440px;
        padding: 50px 60px;
        background-color: white; /* Solid white ko transparent kiya */
        display: flex;
        flex-direction: column;
        justify-content: center;
        z-index: 2;
      }

      .auth-card h2 {
        color: var(--text-primary);
        font-size: 26px;
        margin-bottom: 30px;
        text-align: center;
        color: black;  
      }

      .input-group input {
        width: 100%;
        height: 55px;
        padding: 10px 0; /* Padding adjust ki line ke liye */
        background-color: transparent; /* Box background remove kiya */
        border: none;
        border-bottom: 1px solid var(--input-border); /* Sirf niche ki line */
        color: var(--text-primary);
        /* color */
        outline:none;
        font-size: 16px;
        transition: all 0.3s ease;
        border-radius: 0; /* Corner radius zero taaki line straight lage */
        border-color: black;
      }

      .input-group input:focus {
        border-color: rgb(110, 186, 189); /* Focus karne par line green hogi */
        box-shadow: none; /* Box shadow hata di kyunki ab sirf line hai */
        color: black;
      }

      .btn {
        width: 100%;
        padding: 14px;
        background-color: var(--btn-color);
        /* color: rgb(21, 20, 20); */
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 15px;
        font-weight: 600;
        margin-top: 10px;
        transition: all 0.2s ease;
        text-transform: uppercase;
      }

      .btn:hover {
        background-color: var(--btn-hover);
        transform: translateY(-1px);
      }

      .btn:disabled {
        background-color: #3f6b61;
        cursor: not-allowed;
      }

      .divider {
        text-align: center;
        margin: 0px 0;
        margin-bottom: 5px;
        padding-bottom: 20px;
        padding-top: 0px;
        font-size: 12px;
        color: var(--text-secondary);
        position: relative;
        color: black;
      }

      .google-btn {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid rgba(12, 12, 12, 0.048);
        background: rgba(0, 0, 0, 0.315);
        color: rgb(40, 39, 39);
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        font-size: 14px;
        transition: background 0.3s;
      }

      .google-btn:hover {
        background: rgba(255,255,255,0.15);
      }

      .footer-text {
        text-align: center;
        margin-top: 20px;
        font-size: 13px;
        color: var(--text-secondary);
        color: black;
      }

      .footer-text a {
        color: var(--btn-color);
        text-decoration: none;
        font-weight: 600;
      }

      #errorMsg {
        color: #f87171;
        font-size: 13px;
        text-align: center;
        margin-top: 10px;
        min-height: 18px;
      }

      @media (max-width: 860px) {
        .welcome-section { display: none; }
        .login-page-wrapper { width: 95%; max-width: 400px; height: auto; }
        .auth-card { width: 100%; padding: 40px 30px; }
      }
    </style>
  </head>
  <body>
    <div class="login-page-wrapper">
      <div class="modal-bg-base"></div>

      <div class="welcome-section">
        <h1>Welcome Back</h1>
        <p>Log in to manage your reports and help our community stay connected.</p>
      </div>

      <div class="auth-card">
        <h2>Log In</h2>

        <form id="loginForm">
          <div class="input-group">
            <!-- <label>Email</label> -->
            <input
              type="email"
              id="username"
              placeholder="Enter your email"
              required
            />
          </div>

          <div class="input-group">
            <!-- <label>Password</label> -->
            <input
              type="password"
              id="pwd1"
              placeholder="Enter password"
              required
            />
          </div>

          <button type="submit" class="btn" id="loginBtn">Login</button>
        </form>

        <p id="errorMsg"></p>

        <div class="divider">OR</div>

        <a href="/auth/google" class="google-btn">
          <i class="fa-brands fa-google" style="color: #ff4b4b"></i>
          Continue with Google
        </a>

        <p class="footer-text">
          Don't have an account? <a href="/signup">Sign Up</a>
        </p>
      </div>
    </div>

    <script>
      /* JS logic remains untouched */
      document
        .getElementById("loginForm")
        .addEventListener("submit", async function (e) {
          e.preventDefault();

          const btn = document.getElementById("loginBtn");
          const errorMsg = document.getElementById("errorMsg");
          btn.disabled = true;
          btn.textContent = "Logging in…";
          errorMsg.textContent = "";

          try {
            const res = await fetch("/login", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                username: document.getElementById("username").value,
                password: document.getElementById("pwd1").value,
              }),
            });

            const data = await res.json();

            if (data.success) {
              window.location.href = "/dashboard";
            } else {
              errorMsg.textContent =
                data.message || "Invalid email or password";
              btn.disabled = false;
              btn.textContent = "Login";
            }
          } catch (err) {
            errorMsg.textContent = "Server error. Please try again.";
            btn.disabled = false;
            btn.textContent = "Login";
          }
        });
    </script>
  </body>
</html>