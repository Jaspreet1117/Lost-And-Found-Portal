      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 32px;
      background: white;
      box-shadow: 0 1px 4px rgba(0,0,0,0.04);
      font-weight: 500;
    }
    .logo {
      font-size: 1.2rem;
      font-weight: 600;
      background: linear-gradient(135deg, #2563eb, #7c3aed);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .nav-right {
      display: flex;
