<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= user.name %> - Profile</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Poppins", sans-serif;
      }

      body {
        background: linear-gradient(135deg, #f3ece3, #e8dccb);
        display: flex;
        min-height: 100vh;
        color: #333;
      }

      /* SIDEBAR */
      .sidebar {
        width: 120px;
        background: linear-gradient(180deg, #05122c, #1e3a8a);
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 25px;
        gap: 30px;
        color: white;
        z-index: 100;
      }

      .sidebar a {
        color: white;
        text-decoration: none;
        font-size: 14px;
        cursor: pointer;
        transition: opacity 0.2s;
      }

      .sidebar a:hover {
        opacity: 0.7;
        text-decoration: underline;
      }

      /* MAIN AREA */
      .main {
        flex: 1;
        padding: 20px 40px;
        background: #faf6f0;
        margin: 20px 20px 20px 140px;
        border-radius: 18px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
      }

      /* COVER SECTION */
      .cover {
        height: 250px;
        border-radius: 40px;
        position: relative;
        overflow: hidden;
      }

      .cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .cover::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
          135deg,
          rgba(37, 99, 235, 0.4),
          rgba(30, 58, 138, 0.5)
        );
      }

      .cover-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        color: white;
        z-index: 2;
        width: 100%;
      }

      /* PROFILE OVERLAP BAR */
      .profile-bar {
        background: #fffaf5;
        margin: -40px 20px 0 20px;
        border-radius: 15px;
        padding: 20px 30px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        z-index: 3;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
      }

      .profile-left {
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .avatar {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        border: 5px solid white;
        object-fit: cover;
        background: #eee;
      }

      .profile-info h3 {
        font-size: 22px;
        color: #05122c;
      }
      .profile-info p {
        font-size: 14px;
        color: #666;
        margin-bottom: 10px;
      }

      .profile-buttons button {
        background: #e8dccb;
        border: none;
        padding: 8px 18px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 500;
        transition: background 0.2s;
      }

      .profile-buttons .pass-btn {
        background: #2563eb;
        color: white;
      }

      /* STATS SECTION */
      .stats {
        display: flex;
        gap: 40px;
      }

      .stats div {
        text-align: center;
        line-height: 1.4;
      }
      .stats b {
        font-size: 20px;
        color: #1e3a8a;
      }

      /* INFORMATION CARD */
      .card {
        background: #fffaf5;
        padding: 30px;
        border-radius: 12px;
        margin-top: 25px;
      }

      .card h3 {
        margin-bottom: 15px;
        color: #0f234d;
        border-bottom: 2px solid #e8dccb;
        display: inline-block;
      }
      .card p {
        margin-bottom: 8px;
        font-size: 15px;
      }

      /* MODALS */
      .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        justify-content: center;
        align-items: center;
        z-index: 1000;
      }

      .modal-content {
        background: white;
        padding: 30px;
        border-radius: 15px;
        width: 400px;
        display: flex;
        flex-direction: column;
        gap: 15px;
      }

      .modal-content input,
      .modal-content textarea {
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #ddd;
        width: 100%;
      }

      .modal-buttons {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
      }

      .modal-buttons button {
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        border: none;
      }

      .save-btn {
        background: #1e3a8a;
        color: white;
      }
    </style>
  </head>

  <body>
    <div class="sidebar">
      <a href="/home">Home</a>
      <a href="/lost">Lost</a>
      <a href="/found">Found</a>
      <a href="/messages">Messages</a>
      <a href="/settings">Settings</a>
    </div>

    <div class="main">
      <div class="cover">
        <img
          src="<%= user.coverImage || 'https://i.pinimg.com/1200x/41/74/b9/4174b96d7a37d5982fe53cba5343beab.jpg' %>"
          alt="Cover"
        />
        <div class="cover-text">
          <h2>Welcome, <span id="welcomeName"><%= user.name %></span></h2>
          <p>Helping you reunite with your belongings.</p>
        </div>
      </div>

      <div class="profile-bar">
        <div class="profile-left">
          <img
            id="avatar"
            src="<%= user.profileImage || 'https://cdn-icons-png.flaticon.com/512/3135/3135715.png' %>"
            class="avatar"
          />
          <div class="profile-info">
            <h3 id="name"><%= user.name %></h3>
            <p><%= user.role || 'Community Member' %></p>

            <div class="profile-buttons">
              <button onclick="openEdit()">Edit Profile</button>
              <button class="pass-btn" onclick="openPasswordBox()">
                Security
              </button>
            </div>
          </div>
        </div>

        <div class="stats">
          <div><b><%= user.stats ? user.stats.lost : 0 %></b><br />Lost</div>
          <div><b><%= user.stats ? user.stats.found : 0 %></b><br />Found</div>
          <div>
            <b><%= user.stats ? user.stats.returned : 0 %></b><br />Returned
          </div>
        </div>
      </div>

      <div class="card">
        <h3>Bio & Contact</h3>
        <p id="bio"><i><%= user.bio || 'No bio provided yet.' %></i></p>
        <br />
        <p><b>Email:</b> <span id="email"><%= user.email %></span></p>
        <p>
          <b>Phone:</b>
          <span id="phone"><%= user.phone || 'Not provided' %></span>
        </p>
        <p>
          <b>Campus:</b>
          <span id="campus"><%= user.campus || 'Not assigned' %></span>
        </p>
      </div>
    </div>

    <div class="modal" id="editModal">
      <div class="modal-content">
        <h3>Update Profile</h3>
        <input
          type="text"
          id="editName"
          placeholder="Name"
          value="<%= user.name %>"
        />
        <input
          type="text"
          id="editPhone"
          placeholder="Phone"
          value="<%= user.phone %>"
        />
        <input
          type="text"
          id="editCampus"
          placeholder="Campus"
          value="<%= user.campus %>"
        />
        <textarea id="editBio" placeholder="Tell us about yourself...">
<%= user.bio %></textarea
        >
        <div class="modal-buttons">
          <button onclick="closeEdit()">Cancel</button>
          <button class="save-btn" onclick="saveProfile()">Save Changes</button>
        </div>
      </div>
    </div>

    <script>
      function openEdit() {
        document.getElementById("editModal").style.display = "flex";
      }
      function closeEdit() {
        document.getElementById("editModal").style.display = "none";
      }

      function saveProfile() {
        // Local UI update logic
        const newName = document.getElementById("editName").value;
        if (newName) {
          document.getElementById("name").innerText = newName;
          document.getElementById("welcomeName").innerText = newName;
        }
        // In a real app, you would fetch('/update-profile', { method: 'POST', body: ... })
        closeEdit();
      }

      function openPasswordBox() {
        alert("Security settings coming soon!");
      }
    </script>
  </body>
</html>
