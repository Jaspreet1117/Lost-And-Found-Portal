<!-- Redesigned Profile Page UI (Pastel Orange + Green + Blue Theme) -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= user.name %> - Profile</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Poppins", sans-serif;
      }

      body {
        min-height: 100vh;
        background: linear-gradient(135deg, #fef6ee, #eef8f1, #eef7fb);
        color: #2f3b36;
        padding: 30px;
      }

      .container {
        max-width: 1200px;
        margin: auto;
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(14px);
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
      }

      .cover {
        height: 260px;
        background: linear-gradient(120deg, #ffd8b5, #d7f5dc, #d7efff);
        position: relative;
        padding: 40px;
        display: flex;
        align-items: end;
      }

      .welcome h1 {
        font-size: 34px;
        color: #234;
        margin-bottom: 8px;
      }

      .welcome p {
        color: #4b5b58;
        font-size: 15px;
      }

      .profile-bar {
        margin-top: -55px;
        padding: 0 40px 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
      }

      .left {
        display: flex;
        align-items: center;
        gap: 22px;
      }

      .avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 6px solid white;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        background: white;
      }

      .info h2 {
        font-size: 26px;
        color: #1f3a37;
      }

      .role {
        color: #688178;
        margin: 6px 0 14px;
        font-size: 14px;
      }

      .btns button {
        border: none;
        padding: 11px 18px;
        border-radius: 14px;
        cursor: pointer;
        font-weight: 600;
        margin-right: 10px;
      }

      .edit-btn {
        background: #ffe4c8;
        color: #7a4d1d;
      }

      .pass-btn {
        background: #d8f4df;
        color: #256245;
      }

      .stats {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
      }

      .stat-card {
        min-width: 120px;
        background: white;
        padding: 18px;
        border-radius: 18px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      }

      .stat-card h3 {
        font-size: 24px;
        color: #2d5b70;
      }

      .content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        padding: 10px 40px 40px;
      }

      .card {
        background: white;
        padding: 28px;
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
      }

      .card h3 {
        margin-bottom: 18px;
        color: #234;
      }

      .line {
        margin-bottom: 14px;
        line-height: 1.7;
      }

      .label {
        font-weight: 600;
      }

      @media (max-width: 900px) {
        .content {
          grid-template-columns: 1fr;
        }

        .profile-bar {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="cover">
        <div class="welcome">
          <h1>Welcome, <%= user.name %></h1>
          <p>Your lost & found journey, beautifully organized.</p>
        </div>
      </div>

      <div class="profile-bar">
        <div class="left">
          <img
            class="avatar"
            src="<%= user.profilePic || '/images/default.png' %>"
            alt="profile"
          />

          <div class="info">
            <h2><%= user.name %></h2>
            <div class="role"><%= user.role || 'Community Member' %></div>

            <div class="btns">
              <button class="edit-btn">Edit Profile</button>
              <button class="pass-btn">Change Password</button>
            </div>
          </div>
        </div>

        <div class="stats">
          <div class="stat-card">
            <h3><%= user.stats ? user.stats.lost : 0 %></h3>
            <p>Lost</p>
          </div>
          <div class="stat-card">
            <h3><%= user.stats ? user.stats.found : 0 %></h3>
            <p>Found</p>
          </div>
          <div class="stat-card">
            <h3><%= user.stats ? user.stats.returned : 0 %></h3>
            <p>Returned</p>
          </div>
        </div>
      </div>

      <div class="content">
        <div class="card">
          <h3>Bio & Contact</h3>
          <div class="line">
            <span class="label">Bio:</span> <%= user.bio || 'No bio added yet.'
            %>
          </div>
          <div class="line">
            <span class="label">Email:</span> <%= user.email %>
          </div>
          <div class="line">
            <span class="label">Phone:</span> <%= user.phone || 'Not provided'
            %>
          </div>
          <div class="line">
            <span class="label">Campus:</span> <%= user.campus || 'Not assigned'
            %>
          </div>
        </div>

        <div class="card">
          <h3>Quick Summary</h3>
          <div class="line">
            Keep your details updated so people can reach you faster when your
            items are found.
          </div>
          <div class="line">
            Your profile helps improve trust and successful returns.
          </div>
        </div>
      </div>
    </div>

    <script>
      // Profile Modal Logic
      function openEdit() {
        document.getElementById("editModal").style.display = "flex";
      }
      function closeEdit() {
        document.getElementById("editModal").style.display = "none";
      }

      async function saveProfile() {
        const name = document.getElementById("editName").value;
        const phone = document.getElementById("editPhone").value;
        const campus = document.getElementById("editCampus").value;
        const bio = document.getElementById("editBio").value;

        try {
          const res = await fetch("/profile/update", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              name,
              phone,
              campus,
              bio,
            }),
          });

          const data = await res.json();

          if (data.success) {
            document.getElementById("name").innerText = name;
            document.getElementById("welcomeName").innerText = name;
            document.getElementById("phone").innerText = phone;
            document.getElementById("campus").innerText = campus;
            document.getElementById("bio").innerText = bio;

            alert("Profile updated successfully!");
            closeEdit();
          } else {
            alert(data.message || "Update failed");
          }
        } catch (error) {
          console.error(error);
          alert("Server error");
        }
      }

      // Password Modal Logic
      function openPasswordBox() {
        document.getElementById("passwordModal").style.display = "flex";
      }
      function closePasswordBox() {
        document.getElementById("passwordModal").style.display = "none";
      }

      async function savePassword() {
        const oldPassword = document.getElementById("oldPass").value;
        const newPassword = document.getElementById("newPass").value;
        const confirmPassword = document.getElementById("confirmPass").value;

        if (!oldPassword || !newPassword || !confirmPassword) {
          alert("Please fill all fields");
          return;
        }

        if (newPassword !== confirmPassword) {
          alert("New passwords do not match");
          return;
        }

        try {
          const res = await fetch("/change-password", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              oldPassword,
              newPassword,
              confirmPassword,
            }),
          });

          const data = await res.json();

          if (data.success) {
            alert("Password updated successfully!");

            document.getElementById("oldPass").value = "";
            document.getElementById("newPass").value = "";
            document.getElementById("confirmPass").value = "";

            closePasswordBox();
          } else {
            alert(data.message || "Password update failed");
          }
        } catch (error) {
          console.error(error);
          alert("Server error");
        }
      }
    </script>
  </body>
</html>
